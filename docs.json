{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Cold Navigator API",
  "colors": {
    "primary": "#0F172A",
    "light": "#3B82F6",
    "dark": "#1E40AF"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.coldnavigator.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://app.coldnavigator.com/settings?tab=api-keys"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "index",
              "quickstart",
              "authentication"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.yaml"
      },
      {
        "tab": "Webhooks",
        "groups": [
          {
            "group": "Webhooks Guide",
            "pages": [
              "webhooks/overview",
              "webhooks/event-types",
              "webhooks/payload-format",
              "webhooks/signature-verification",
              "webhooks/retry-policy"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Integration Guides",
            "pages": [
              "guides/make-com",
              "guides/n8n",
              "guides/zapier",
              "guides/ai-lead-qualification"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.coldnavigator.com",
          "icon": "gauge"
        },
        {
          "anchor": "API Keys",
          "href": "https://app.coldnavigator.com/settings?tab=api-keys",
          "icon": "key"
        }
      ]
    }
  },
  "openapi": "openapi.yaml",
  "api": {
    "auth": {
      "method": "key",
      "name": "x-api-key"
    },
    "playground": {
      "mode": "simple"
    }
  },
  "footer": {
    "socials": {
      "website": "https://coldnavigator.com",
      "linkedin": "https://linkedin.com/company/cold-navigator"
    }
  }
}
